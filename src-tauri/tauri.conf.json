{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marinara-engine",
  "version": "0.1.0",
  "identifier": "com.marinara-engine.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "marinara-engine",
        "width": 800,
        "height": 600,
        "decorations": false,
        "resizable": true,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/default-data/**/*", "resources/platform-assets/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
